{
  "name": "quick-calc.app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.14.1",
    "pnpm": ">=10.33.0"
  },
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint",
    "prepare": "husky",
    "start": "next start",
    "test": "echo \"No test framework configured yet\" && exit 0",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,mts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "lz-string": "1.5.0",
    "mathjs": "15.1.1",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "20.19.39",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.2",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "postcss-load-config": "6.0.1",
    "prettier": "3.8.1",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3"
  }
}
